<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} &middot; {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ dek or site.description }}">
  <meta name="google-adsense-account" content="{{ site.adsenseClient }}">
  <link rel="stylesheet" href="/assets/css/style.css">
  {% if site.adsenseClient and site.adsenseClient != "" %}
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ site.adsenseClient }}" crossorigin="anonymous"></script>
  {% endif %}
</head>
<body>
  {% include "partials/header.njk" %}
  {{ content | safe }}
  {% include "partials/footer.njk" %}
</body>
</html>
